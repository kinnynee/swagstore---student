<div class="page-container">
  <div class="page-header">
    <a href="/staff/products" class="back-link">Back to Staff Products</a>
    <h1 class="page-title">Order for Customer</h1>
    <p class="page-subtitle">Create a customer order from an existing customer account and catalog product.</p>
  </div>

  <form method="POST" action="/staff/orders" class="checkout-form">
    {{#if error}}
    <div class="alert alert-error">{{error}}</div>
    {{/if}}

    <section class="form-section">
      <h2 class="form-section-title">Customer</h2>
      <div class="form-group">
        <label class="form-label">Customer Account</label>
        <select name="customerId" class="form-input" required>
          <option value="">Select customer</option>
          {{#each customers}}
          <option value="{{id}}">{{name}} - {{email}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Recipient Name</label>
          <input type="text" name="name" class="form-input" value="{{form.name}}">
        </div>
        <div class="form-group">
          <label class="form-label">Shipping Address</label>
          <input type="text" name="address" class="form-input" value="{{form.address}}">
        </div>
      </div>
    </section>

    <section class="form-section">
      <h2 class="form-section-title">Product</h2>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Product</label>
          <select name="productId" class="form-input" required>
            <option value="">Select product</option>
            {{#each products}}
            <option value="{{id}}">{{name}} - ${{price}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Quantity</label>
          <input type="number" name="qty" class="form-input" min="1" step="1" value="{{form.qty}}" required>
        </div>
      </div>
    </section>

    <button type="submit" class="btn-primary btn-large">Place Customer Order</button>
  </form>
</div>
